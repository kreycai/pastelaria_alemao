{
  "expo": {
    "name": "Pastelaria Alemão",
    "slug": "pastelaria-alemao",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "pastelaria",
    "backgroundColor": "#09090b",
    "splash": {
      "backgroundColor": "#09090b",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.pastelaria.alemao"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#09090b"
      },
      "package": "com.pastelaria.alemao",
      "softwareKeyboardLayoutMode": "pan"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6bdf7163-58bb-4864-805d-8e2b37567cb7"
      }
    }
  }
}
