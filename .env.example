# =============================================================================
# pastelaria_alemao - Variáveis de Ambiente
# Copie este arquivo para .env nos apps que precisarem (nunca commit o .env real)
# =============================================================================

# ── DATABASE (NeonTech) ───────────────────────────────────────────────────────
# Obtenha em: https://console.neon.tech → seu projeto → Connection string
# Use a string "pooled" para o runtime (API)
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/pastelaria_db?sslmode=require"
# Use a string "direct" para migrations do Prisma
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/pastelaria_db?sslmode=require"

# ── API ───────────────────────────────────────────────────────────────────────
API_PORT=3001
NODE_ENV=development

# ── NEXT.JS FRONTEND ─────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"
