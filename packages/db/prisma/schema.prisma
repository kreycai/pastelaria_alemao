generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enumerações ─────────────────────────────────────────────────────────────

enum TipoPastel {
  SALGADO
  DOCE
}

enum StatusPedido {
  PENDENTE
  EM_PREPARO
  PRONTO
  ENTREGUE
  CANCELADO
}

enum MetodoPagamento {
  DINHEIRO
  PIX
  CARTAO_DEBITO
  CARTAO_CREDITO
  FIADO
}

enum UnidadeMateriaPrima {
  KG
  UNIDADE
}

// ─── Modelos ──────────────────────────────────────────────────────────────────

model MateriaPrima {
  id            String              @id @default(cuid())
  nome          String
  unidade       UnidadeMateriaPrima @default(KG)
  precoKg       Decimal             @db.Decimal(10, 2) @map("preco_kg")
  estoqueGramas Decimal             @default(0) @db.Decimal(10, 3) @map("estoque_gramas")
  estoqueMinimo Decimal             @default(0) @db.Decimal(10, 3) @map("estoque_minimo")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  ingredientes PastelIngrediente[]

  @@map("materias_primas")
}

model PastelIngrediente {
  id               String  @id @default(cuid())
  pastelId         String  @map("pastel_id")
  materiaPrimaId   String  @map("materia_prima_id")
  quantidadeGramas Decimal @db.Decimal(10, 3) @map("quantidade_gramas")

  pastel       Pastel       @relation(fields: [pastelId], references: [id], onDelete: Cascade)
  materiaPrima MateriaPrima @relation(fields: [materiaPrimaId], references: [id])

  @@unique([pastelId, materiaPrimaId])
  @@map("pastel_ingredientes")
}

model Pastel {
  id         String     @id @default(cuid())
  nome       String
  descricao  String?
  preco      Decimal    @db.Decimal(10, 2)
  tipo       TipoPastel
  disponivel Boolean    @default(true)
  imagemUrl  String?
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  ingredientes PastelIngrediente[]
  itensPedido  ItemPedido[]

  @@map("pasteis")
}

model Cliente {
  id        String   @id @default(cuid())
  nome      String
  telefone  String?
  email     String?  @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  pedidos Pedido[]

  @@map("clientes")
}

model Pedido {
  id                  String          @id @default(cuid())
  status              StatusPedido    @default(PENDENTE)
  total               Decimal         @db.Decimal(10, 2)
  observacao          String?
  clienteId           String?         @map("cliente_id")
  metodoPagamento     MetodoPagamento @default(DINHEIRO) @map("metodo_pagamento")
  nomeCliente         String?         @map("nome_cliente")
  previsaoPagamento   DateTime?       @map("previsao_pagamento")
  fiadoPago           Boolean         @default(false) @map("fiado_pago")
  fiadoPagoEm         DateTime?       @map("fiado_pago_em")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  cliente Cliente?     @relation(fields: [clienteId], references: [id])
  itens   ItemPedido[]

  @@map("pedidos")
}

model ItemPedido {
  id         String  @id @default(cuid())
  quantidade Int
  precoUnit  Decimal @db.Decimal(10, 2) @map("preco_unit")
  pedidoId   String  @map("pedido_id")
  pastelId   String  @map("pastel_id")

  pedido Pedido @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  pastel Pastel @relation(fields: [pastelId], references: [id])

  @@map("itens_pedido")
}
